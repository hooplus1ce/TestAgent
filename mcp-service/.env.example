# Loaded automatically by drissionpage-mcp when present. Existing process
# environment variables take precedence over values in this file.
# Required only by refresh_session/login_ocr.
HL_SCM_USERNAME=
HL_SCM_USERPWD=

# Role-specific credentials for approval regression. One logical role maps to one
# isolated BrowserContext. Do not reuse the default variables above for these roles.
# role_id=requester
HL_SCM_ROLE_REQUESTER_USERNAME=
HL_SCM_ROLE_REQUESTER_USERPWD=
# role_id=dept_manager
HL_SCM_ROLE_DEPT_MANAGER_USERNAME=
HL_SCM_ROLE_DEPT_MANAGER_USERPWD=
# role_id=finance_approver
HL_SCM_ROLE_FINANCE_APPROVER_USERNAME=
HL_SCM_ROLE_FINANCE_APPROVER_USERPWD=

# Optional runtime configuration.
# DRISSIONPAGE_MCP_PROFILE=full  # use enterprise only when intentionally reducing model context
# DRISSIONPAGE_MCP_CONFIG_DIR=custom-configs
# DRISSIONPAGE_MCP_WORKSPACE_ROOT=/absolute/path/to/workspace
# DRISSIONPAGE_MCP_CAPS=all  # use core,roles,... when capability groups are restricted
# HL_REMOTE_PORT=9222
# HL_TARGET_HINT=
# HL_SHOT_DIR=/absolute/path/to/evidence
