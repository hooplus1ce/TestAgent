{
    "mcpServers": {
        "drissionpage-mcp": {
            "command": "uv",
            "args": [
                "run",
                "--project",
                "mcp-service",
                "python",
                "mcp-service/launcher.py"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "DRISSIONPAGE_MCP_CAPS": "all"
            }
        }
    }
}
