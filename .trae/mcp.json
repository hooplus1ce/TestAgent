{
    "mcpServers": {
        "drissionpage-mcp": {
            "command": "uv",
            "args": [
                "run",
                "--package",
                "drissionpage-mcp",
                "-m",
                "drissionpage_mcp"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "DRISSIONPAGE_MCP_PROFILE": "full",
                "DRISSIONPAGE_MCP_CAPS": "all"
            }
        }
    }
}
