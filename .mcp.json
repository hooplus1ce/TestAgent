{
    "mcpServers": {
        "drissionpage-mcp": {
            "command": "uv",
            "args": [
                "run",
                "--package",
                "drissionpage-mcp",
                "-m",
                "drissionpage_mcp"
            ],
            "env": {
                "DRISSIONPAGE_MCP_PROFILE": "full",
                "DRISSIONPAGE_MCP_CAPS": "all",
                "DRISSIONPAGE_MCP_WARMUP_OCR": "false",
                "DRISSIONPAGE_MCP_COMPONENT_RELOAD": "true",
                "DRISSIONPAGE_MCP_DISCOVERY": "search",
                "DRISSIONPAGE_MCP_OBSERVABILITY": "true"
            }
        }
    }
}
