# Loaded automatically by drissionpage-mcp from the workspace root. Existing
# process environment variables take precedence over values in this file.

# Required only by refresh_session/login_ocr.
HL_SCM_USERNAME=
HL_SCM_USERPWD=

# Role-specific credentials for isolated approval regression sessions.
HL_SCM_ROLE_REQUESTER_USERNAME=
HL_SCM_ROLE_REQUESTER_USERPWD=
HL_SCM_ROLE_DEPT_MANAGER_USERNAME=
HL_SCM_ROLE_DEPT_MANAGER_USERPWD=
HL_SCM_ROLE_FINANCE_APPROVER_USERNAME=
HL_SCM_ROLE_FINANCE_APPROVER_USERPWD=

# Optional target and runtime overrides.
# HL_SCM_URL=https://example.com/scm-static/scm-admin/scm-admin/#/
# HL_SCM_BASE_URL=https://example.com
# HL_SCM_LOGIN_PAGE=https://example.com/meLogin.do?
# HL_COOKIE_DOMAIN=.example.com
# HL_ACCESS_DOMAIN=.example.com
# HL_REMOTE_PORT=9222
# HL_TARGET_HINT=
# HL_SHOT_DIR=D:/path/to/evidence
# HL_HEADLESS=false
# HL_PROXY=
# HL_REFRESH_NAV_TIMEOUT=10
# HL_REFRESH_LOAD_TIMEOUT=15
# HL_REFRESH_HTTP_TIMEOUT=15

# Optional MCP surface and path overrides.
# DRISSIONPAGE_MCP_PROFILE=full
# DRISSIONPAGE_MCP_CAPS=all
# DRISSIONPAGE_MCP_CONFIG_DIR=D:/path/to/configs
# DRISSIONPAGE_MCP_WORKSPACE_ROOT=D:/path/to/workspace
