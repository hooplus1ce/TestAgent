# =============================================================================
# TestAgent 环境变量配置模板
# =============================================================================
# 用法：复制本文件为 .env，填入实际值。.env 已被 gitignore，不会被提交。
# 已存在的进程环境变量优先于此文件中的值。
#
# 变量按用途分组：
#   1. 必备凭据 —— 登录必须配置
#   2. 多角色审批凭据 —— 审批回归场景按需配置
#   3. 目标系统地址 —— SCM 系统连接信息（无默认值，必须设置）
#   4. 浏览器与运行时 —— Chrome/Edge 连接与行为
#   5. 超时控制 —— 会话刷新超时
#   6. MCP 服务面 —— 工具暴露范围与路径覆盖
# =============================================================================

# ---------------------------------------------------------------------------
# 1. 必备凭据
# refresh_session / login_ocr / login_role 等工具需要此默认账号登录 SCM。
# ---------------------------------------------------------------------------
HL_USERNAME=       # SCM 登录用户名
HL_USERPWD=        # SCM 登录密码

# ---------------------------------------------------------------------------
# 2. 多角色审批凭据
# 审批回归场景中每个业务角色使用独立的 BrowserContext 和登录凭据。
# 工具通过 role_id 自动派生变量名：HL_ROLE_<ROLE_ID>_USERNAME/USERPWD。
# 按实际需要配置，不用的角色可留空或注释。
# 标准角色 id：requester / dept_manager / finance_approver
# ---------------------------------------------------------------------------
HL_ROLE_REQUESTER_USERNAME=          # 申请者用户名
HL_ROLE_REQUESTER_USERPWD=           # 申请者密码
HL_ROLE_DEPT_MANAGER_USERNAME=       # 部门经理用户名
HL_ROLE_DEPT_MANAGER_USERPWD=        # 部门经理密码
HL_ROLE_FINANCE_APPROVER_USERNAME=   # 财务审批人用户名
HL_ROLE_FINANCE_APPROVER_USERPWD=    # 财务审批人密码

# ---------------------------------------------------------------------------
# 3. 目标系统地址
# SCM 系统的入口 URL 和相关端点。无默认值，启动前必须正确配置。
# 推荐使用 HL_HOST_PREFIX 一键配置（自动推导 5 个关联 URL），
# 也支持逐个变量覆盖（优先级更高）。
# ---------------------------------------------------------------------------
# HL_HOST_PREFIX=       # 一键切换环境，自动推导 HL_URL / HL_BASE_URL / HL_LOGIN_PAGE /
#                       # HL_COOKIE_DOMAIN / HL_ACCESS_DOMAIN 共 5 个配置。
#                       # 示例：demo15-scm  → https://demo15-scm.hoolinks.com/...
#                       #       demo19-scm  → https://demo19-scm.hoolinks.com/...
# HL_URL=               # SCM Admin 入口 URL（hash 路由 SPA 完整路径）
#                       # 例如：https://your-company.scm.com/scm-admin/#/
# HL_BASE_URL=          # SCM 站点根 URL，用于 OCR 登录的 HTTP 请求
#                       # 例如：https://your-company.scm.com
# HL_LOGIN_PAGE=        # 登录页面完整 URL（作为 Referer 头）
#                       # 例如：https://your-company.scm.com/meLogin.do?
# HL_COOKIE_DOMAIN=     # Cookie 所属域名，用于会话维持
#                       # 例如：.your-company.scm.com
# HL_ACCESS_DOMAIN=     # CDP 注入 cookie 时使用的域名
#                       # 例如：.your-company.com

# ---------------------------------------------------------------------------
# 4. 浏览器与运行时
# Chrome/Edge 连接、代理、截图保存路径等。
# ---------------------------------------------------------------------------
# HL_REMOTE_PORT=9222          # Chrome 远程调试端口，默认 9222
# HL_TARGET_HINT=              # connect 时按页面标题选择标签页的关键词
#                              # 留空时使用默认值"诺贝科技"
# HL_SHOT_DIR=                 # 截图/证据文件保存目录
#                              # 默认：mcp-service/resources/
# HL_HEADLESS=false            # 无头模式（CI/CD 无图形环境时设为 true）
# HL_PROXY=                    # HTTP 代理地址，例如 http://127.0.0.1:1080
# HL_CHROME_PATH=              # Chrome/Chromium 浏览器可执行文件路径
#                              # 留空则使用 DrissionPage 自动查找
# HL_EDGE_MODE=false           # 设为 true 时使用 Edge 替代 Chrome
# HL_DISABLE_PDF_PREVIEW=false # 设为 true 时禁用 Chrome 内置 PDF 预览
# HL_REMOVE_TEST_TYPE=false    # 设为 true 时移除测试类型标记

# ---------------------------------------------------------------------------
# 5. 超时控制
# 会话刷新操作（refresh_session / login_ocr）的超时配置。
# 这些操作需要短超时，避免 MCP 单次工具调用被页面加载拖到外层超时。
# ---------------------------------------------------------------------------
# HL_REFRESH_NAV_TIMEOUT=10    # 导航等待超时（秒）
# HL_REFRESH_LOAD_TIMEOUT=15   # 页面加载等待超时（秒）
# HL_REFRESH_HTTP_TIMEOUT=15   # HTTP 请求超时（秒）

# ---------------------------------------------------------------------------
# 6. MCP 服务面
# 控制暴露给 LLM 的工具集范围与路径覆盖。
# ---------------------------------------------------------------------------
# DRISSIONPAGE_MCP_PROFILE=full          # 工具面：full（全部）| enterprise（精简）
# DRISSIONPAGE_MCP_CAPS=all              # 能力分组白名单，逗号分隔
#                                        # 例如：core, vtable, role, network
#                                        # all 表示启用所有分组
# DRISSIONPAGE_MCP_CONFIG_DIR=           # DrissionPage 配置 (.ini) 所在目录
#                                        # 默认：mcp-service/configs/
# DRISSIONPAGE_MCP_WORKSPACE_ROOT=       # 工作区根目录（项目根）
#                                        # 默认自动探测
# DRISSIONPAGE_MCP_ENV_FILE=             # .env 文件路径，默认读取项目根 .env
#                                        # 需要自定义路径时设置此项
# DRISSIONPAGE_MCP_WARMUP_OCR=true       # 启动时预热 OCR；开发热重载可设为 false
# DRISSIONPAGE_MCP_COMPONENT_RELOAD=false # 每次目录请求重扫 components；仅开发时启用
# DRISSIONPAGE_MCP_DISCOVERY=full          # full | search；Agent 推荐 search
# DRISSIONPAGE_MCP_SEARCH_MAX_RESULTS=5    # 单次工具搜索最多返回数量
# DRISSIONPAGE_MCP_OBSERVABILITY=true      # 安全结构化日志 + 工具耗时统计
# DRISSIONPAGE_MCP_ERROR_TRACEBACK=false   # 是否向 Agent 返回服务端堆栈；仅本地调试开启
# DRISSIONPAGE_MCP_RESPONSE_MAX_BYTES=1000000 # 超大扫描/回放响应上限
# DRISSIONPAGE_MCP_WAIT_TOOL_TIMEOUT=45     # 网络/观察等待类工具超时（秒）
